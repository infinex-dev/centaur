# Local-dev environment for the FirenzeStaging Slack bot (k3s-in-podman + env secrets + Socket Mode).
#
# Copy to .env and fill in real values:   cp .env.example .env
# `.env` is gitignored, so your real secrets never get committed.
#
# `just` auto-loads .env (set dotenv-load := true). contrib/scripts/deploy-local.sh
# does NOT — load it into your shell first:
#     set -a; source .env; set +a
#     contrib/scripts/deploy-local.sh

# --- Required ---
# From the FirenzeStaging Slack app (api.slack.com/apps):
#   OAuth & Permissions -> Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-replace-me
#   Basic Information -> App Credentials -> Signing Secret
SLACK_SIGNING_SECRET=replace-me
#   Basic Information -> App-Level Tokens -> Generate Token and Scopes (connections:write)
SLACK_APP_TOKEN=xapp-replace-me
# Socket Mode removes the need for ngrok/public Slack Request URLs in local/staging.
SLACK_SOCKET_MODE=1
# Model key for the default (codex) harness — from wherever you keep it (no 1Password):
OPENAI_API_KEY=sk-replace-me
# --- Optional model keys (only if the harness/tools use them) ---
# ANTHROPIC_API_KEY=
# AMP_API_KEY=

# --- Optional overrides (sensible defaults; uncomment to change) ---
# CENTAUR_NAMESPACE=centaur                        # kube namespace (matches the justfile default)
# CENTAUR_RELEASE=centaur                          # helm release name
# CENTAUR_PODMAN_MACHINE=podman-machine-default    # podman machine that hosts k3s
# CENTAUR_KUBECONFIG=~/.kube/centaur-k3s.yaml      # where k3s-local.sh writes the kubeconfig
