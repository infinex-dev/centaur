{
  "uid": "operations",
  "title": "Operations",
  "description": "Execution throughput, latency, queue depth, warm pool, tool calls, delivery backlog.",
  "tags": ["centaur"],
  "schemaVersion": 39,
  "graphTooltip": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-3h", "to": "now" },
  "timezone": "utc",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Executions Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "last_over_time(agent_execution_requests{status=\"running\"}[5m])", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0" } }
    },
    {
      "id": 2,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "last_over_time(agent_execution_requests{status=\"queued\"}[5m])", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 10 }] } } }
    },
    {
      "id": 3,
      "title": "Active Sessions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "last_over_time(agent_sessions_active[5m])", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0" } }
    },
    {
      "id": 4,
      "title": "Warm Pool",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "last_over_time(agent_warm_pool_containers{state=\"available\"}[5m])", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0" } }
    },
    {
      "id": 5,
      "title": "Delivery Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(last_over_time(agent_final_delivery_outbox{state=~\"pending|sending|retry_wait\"}[5m]))", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }] } } }
    },
    {
      "id": 6,
      "title": "Watchdog Timeouts",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(increase(agent_execution_watchdog_timeouts_total[1h]))", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } } }
    },
    {
      "id": 10,
      "title": "Execution Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(increase(agent_executions_enqueued_total[5m]))", "legendFormat": "enqueued", "refId": "A" },
        { "expr": "sum(increase(agent_executions_claimed_total[5m]))", "legendFormat": "claimed", "refId": "B" },
        { "expr": "sum by (status) (increase(agent_execution_terminal_total[5m]))", "legendFormat": "{{status}}", "refId": "C" }
      ]
    },
    {
      "id": 11,
      "title": "Execution Duration p50 / p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_execution_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_execution_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } }
    },
    {
      "id": 12,
      "title": "Queue Delay p50 / p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_execution_queue_delay_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_execution_queue_delay_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } }
    },
    {
      "id": 13,
      "title": "Tool Calls / sec",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "topk(10, sum by (tool_name) (rate(agent_tool_calls_total[5m])))", "legendFormat": "{{tool_name}}", "refId": "A" }
      ]
    },
    {
      "id": 14,
      "title": "Tool Call Latency p95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum by (le, tool_name) (rate(agent_tool_call_duration_seconds_bucket[5m]))))", "legendFormat": "{{tool_name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0 } }
    },
    {
      "id": 15,
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "topk(10, sum by (path) (rate(http_requests_total{path!~\"/health.*|/metrics\"}[5m])))", "legendFormat": "{{path}}", "refId": "A" }
      ]
    },
    {
      "id": 16,
      "title": "Token Usage / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum by (token_type) (rate(agent_usage_tokens_total[5m])) * 60", "legendFormat": "{{token_type}}", "refId": "A" }
      ]
    },
    {
      "id": 17,
      "title": "Terminal Reasons",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum by (terminal_reason) (increase(agent_execution_terminal_total[5m]))", "legendFormat": "{{terminal_reason}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    }
  ]
}
