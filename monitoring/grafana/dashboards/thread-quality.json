{
  "uid": "thread-quality",
  "title": "Thread Quality",
  "description": "Thread-level quality signals: TTFT, 1-shot success rate, tool error classification, retries, per-user volume.",
  "tags": ["centaur", "quality"],
  "schemaVersion": 39,
  "graphTooltip": 1,
  "editable": true,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "utc",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "1-Shot Success Rate",
      "description": "% of first executions per thread that completed successfully",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(last_over_time(agent_oneshot_total{success=\"true\"}[1h])) / clamp_min(sum(last_over_time(agent_oneshot_total[1h])), 1)", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "noValue": "—", "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "green", "value": 0.9 }] } } }
    },
    {
      "id": 2,
      "title": "TTFT p50",
      "description": "Median time to first token",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "histogram_quantile(0.50, sum by (le) (last_over_time(agent_ttft_seconds_bucket[1h])))", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s", "noValue": "—", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 15 }] } } }
    },
    {
      "id": 3,
      "title": "TTFT p95",
      "description": "95th percentile time to first token",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "histogram_quantile(0.95, sum by (le) (last_over_time(agent_ttft_seconds_bucket[1h])))", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "unit": "s", "noValue": "—", "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "red", "value": 30 }] } } }
    },
    {
      "id": 4,
      "title": "Executions Total",
      "description": "Total completed + failed executions",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(last_over_time(agent_execution_terminal_total[1h]))", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value" },
      "fieldConfig": { "defaults": { "noValue": "0" } }
    },
    {
      "id": 10,
      "title": "1-Shot Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum(increase(agent_oneshot_total{success=\"true\"}[30m])) / clamp_min(sum(increase(agent_oneshot_total[30m])), 1)", "legendFormat": "1-shot success rate", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1, "custom": { "fillOpacity": 15 } } }
    },
    {
      "id": 11,
      "title": "TTFT Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_ttft_seconds_bucket[30m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_ttft_seconds_bucket[30m])))", "legendFormat": "p95", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "min": 0, "custom": { "fillOpacity": 10 } } }
    },
    {
      "id": 12,
      "title": "Tool Errors by Category",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum by (category) (increase(agent_tool_error_categories_total[30m]))", "legendFormat": "{{category}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 13,
      "title": "Tool Errors by Tool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "topk(10, sum by (tool_name) (increase(agent_tool_error_categories_total[30m])))", "legendFormat": "{{tool_name}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 15 } } }
    },
    {
      "id": 14,
      "title": "Execution Outcomes",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "sum by (terminal_reason) (increase(agent_execution_terminal_total[30m]))", "legendFormat": "{{terminal_reason}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } } } }
    },
    {
      "id": 15,
      "title": "Executions by User (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        { "expr": "topk(20, sum by (user_id) (last_over_time(agent_execution_by_user_total[6h])))", "format": "table", "instant": true, "refId": "A" }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "user_id": "User", "Value": "Executions" } } }
      ]
    }
  ]
}
