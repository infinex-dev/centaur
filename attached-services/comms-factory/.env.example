# comms-factory environment
# Copy to .env for local CLI/API runs. In Centaur local k3s, set the relevant
# values in centaur-infra-env and mount them into the attached service.

# -----------------------------------------------------------------------------
# API service
# -----------------------------------------------------------------------------

# HTTP port for services/api/server.ts. Docker image defaults to 8080.
PORT=8080

# Runtime mode. In production, the API requires COMMS_FACTORY_SERVICE_TOKEN unless
# COMMS_FACTORY_ALLOW_UNAUTHENTICATED=true.
NODE_ENV=development

# Shared bearer token expected by the comms-factory API.
# Centaur sends this via tools/comms_factory/client.py.
COMMS_FACTORY_SERVICE_TOKEN=change-me

# Only for local throwaway testing. Do not set true in production.
COMMS_FACTORY_ALLOW_UNAUTHENTICATED=false

# Optional build/version metadata returned by /health.
COMMIT_SHA=local

# -----------------------------------------------------------------------------
# Required for live generation, grounding, active validation, and LLM audit
# -----------------------------------------------------------------------------

# Required for /ground live fact grounding, /generate live generation,
# actor/director runs, and director audit. Without this, some routes fall back to
# deterministic/stub behavior, but ground/generate quality will be incomplete.
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional model overrides
# -----------------------------------------------------------------------------

# Grounder model. Default in code: claude-sonnet-4-6.
COMMS_GROUNDER_MODEL=claude-sonnet-4-6

# Copy rewrite / generation model override.
COMMS_GENERATOR_MODEL=claude-sonnet-4-6

# Intent classifier model override.
COMMS_INTENT_MODEL=claude-sonnet-4-6

# Voice validator model override.
COMMS_VOICE_VALIDATOR_MODEL=claude-sonnet-4-6

# Active validator model override.
COMMS_ACTIVE_VALIDATOR_MODEL=claude-sonnet-4-6

# Active validator tool-call loop controls.
COMMS_ACTIVE_VALIDATOR_MAX_TOOL_TURNS=8
COMMS_ACTIVE_VALIDATOR_MAX_TOKENS=4096

# Actor/director pipeline model overrides.
# Defaults in code: actor=claude-opus-4-7, director=COMMS_ACTIVE_VALIDATOR_MODEL
# or claude-sonnet-4-6.
COMMS_ACTOR_MODEL=claude-opus-4-7
COMMS_DIRECTOR_MODEL=claude-sonnet-4-6
COMMS_ANTHROPIC_RETRY_ATTEMPTS=4

# Optional harness selector used by actor/director scripts.
HARNESS_GENERATOR_ARCH=actor

# -----------------------------------------------------------------------------
# Centaur native tool plane (production grounding path)
# -----------------------------------------------------------------------------

# Production /ground runs research through Centaur's native tool plane
# (POST /tools/{tool}/{method}). The attached service receives a SCOPED token
# bound to a research tool bundle; it must NOT receive a broad/admin token or
# Slack, GitHub, ProjectJin, browser, or platform-checkout access.
# For local dev, point CENTAUR_BASE_URL at a mock /tools server.
CENTAUR_BASE_URL=http://api:8000
CENTAUR_TOKEN=
CENTAUR_TIMEOUT_MS=20000

# -----------------------------------------------------------------------------
# Explicit local-dev grounding fallback only
# -----------------------------------------------------------------------------

# These are for local scripts/tests when you intentionally run without Centaur's
# tool plane. Do not configure them for production service deployments.
PLATFORM_ROOT=
COMMS_FACTORY_CACHE_DIR=.cache/comms-factory
FACT_GROUNDER_JSON_API_ALLOWLIST=
PROJECTJIN_BIN=
PROJECTJIN_CLI=
PROJECTJIN_PROFILE=default

# -----------------------------------------------------------------------------
# Optional TTS / Mirodan helper scripts only
# -----------------------------------------------------------------------------

# Used by scripts/generate-mirodan-elevenlabs-*.mjs, not by the API service.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_CHUNK_CHARS=4200
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
ELEVENLABS_FORCE=0

MIRODAN_TTS_SOURCE=
MIRODAN_TTS_OUT_DIR=
MIRODAN_TTS_REUSE_SAMPLE_DIR=
