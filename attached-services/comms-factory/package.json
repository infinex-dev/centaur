{
  "name": "comms-factory",
  "version": "0.0.1",
  "private": true,
  "description": "Automated comms pipeline for Infinex. release event -> release card -> generator -> validator -> orchestrator -> renderer -> ship gate.",
  "type": "module",
  "scripts": {
    "dev": "remotion studio",
    "dev:harness": "pnpm --dir harness dev",
    "db:init": "pnpm --dir harness db:init",
    "render": "tsx src/cli.ts render",
    "generate": "tsx src/cli.ts generate",
    "generate:actor": "tsx scripts/run-actor-director-card.ts",
    "emit-pr": "tsx scripts/emit-pr.ts",
    "draft-blog": "tsx src/cli.ts draft-blog",
    "validate": "tsx src/cli.ts validate",
    "ship": "tsx src/cli.ts ship",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "typecheck:harness": "pnpm --dir harness typecheck",
    "build:harness": "pnpm --dir harness build",
    "service:dev": "tsx services/api/server.ts",
    "service:test": "vitest run services/api/server.test.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@remotion/bundler": "^4.0.460",
    "@remotion/cli": "^4.0.0",
    "@remotion/media": "^4.0.0",
    "@remotion/renderer": "^4.0.460",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsonrepair": "^3.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.0",
    "ulid": "^3.0.2",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^12.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}
