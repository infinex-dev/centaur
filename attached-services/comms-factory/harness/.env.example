# Copy to harness/.env.local for local harness development.
# Next.js loads this file when running from harness/.

ANTHROPIC_API_KEY=
HARNESS_GENERATOR_ARCH=actor
HARNESS_ACTIVE_VALIDATOR=1
HARNESS_ACTOR_WARMUP=scene_rehearsal
HARNESS_DB_PATH=harness.db

COMMS_ACTOR_MODEL=claude-opus-4-7
COMMS_DIRECTOR_MODEL=claude-sonnet-4-6
COMMS_ACTIVE_VALIDATOR_MODEL=claude-sonnet-4-6

HARNESS_ALLOW_STUB_GENERATOR=0
HARNESS_SLACK_WEBHOOK=

# Pin Server Action IDs across dev restarts (generate: openssl rand -base64 32).
# Unset = Next mints a new key each restart -> open tabs 404 with "Server Action not found".
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=
