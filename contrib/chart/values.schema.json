{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "global": {
      "type": "object",
      "properties": {
        "imagePullSecrets": { "type": "array" }
      }
    },
    "attachedServices": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "properties": {
          "enabled": { "type": "boolean" },
          "replicaCount": { "type": "integer", "minimum": 1 },
          "image": {
            "type": "object",
            "properties": {
              "repository": { "type": "string", "minLength": 1 },
              "tag": { "type": "string", "minLength": 1 },
              "pullPolicy": { "type": "string" }
            }
          },
          "service": {
            "type": "object",
            "properties": {
              "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "targetPort": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "portName": { "type": "string" }
            }
          },
          "env": {
            "type": "object",
            "additionalProperties": { "type": ["string", "number", "boolean"] }
          },
          "secretEnv": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "secretName": { "type": "string", "minLength": 1 },
                "key": { "type": "string", "minLength": 1 },
                "optional": { "type": "boolean" }
              },
              "required": ["secretName", "key"]
            }
          },
          "proxy": {
            "type": "object",
            "properties": {
              "enabled": { "type": "boolean" }
            }
          },
          "egressPorts": {
            "type": "array",
            "items": { "type": "integer", "minimum": 1, "maximum": 65535 }
          },
          "serviceKey": {
            "type": "object",
            "description": "Centaur callback API key this attached service uses to call /tools. Bootstrapped from the secret-env token named by envVar.",
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "scopes": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 },
                "minItems": 1
              },
              "envVar": { "type": "string", "minLength": 1 }
            },
            "required": ["name", "scopes", "envVar"]
          },
          "resources": { "type": "object" }
        },
        "required": ["enabled"],
        "allOf": [
          {
            "if": { "properties": { "enabled": { "const": true } } },
            "then": { "required": ["image"] }
          }
        ]
      }
    },
    "firewall": {
      "type": "object",
      "properties": {
        "existingCaSecretName": { "type": "string" },
        "existingCaKeySecretName": { "type": "string" },
        "ca": {
          "type": "object",
          "properties": {
            "certPem": { "type": "string" },
            "keyPem": { "type": "string" }
          }
        }
      }
    },
    "ironProxy": {
      "type": "object",
      "properties": {
        "service": {
          "type": "object",
          "properties": {
            "proxyPort": { "type": "integer" },
            "managementPort": { "type": "integer" },
            "healthPort": { "type": "integer" },
            "pgPortRangeStart": { "type": "integer" },
            "pgPortRangeEnd": { "type": "integer" }
          }
        },
        "secretSource": { "type": "string" },
        "secretTtl": { "type": "string" }
      }
    },
    "secrets": {
      "type": "object",
      "properties": {
        "bootstrapSecretName": { "type": "string" }
      }
    },
    "api": {
      "type": "object",
      "properties": {
        "egressDiscovery": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "clusterDomain": { "type": "string" },
            "tailnetFqdnAnnotation": { "type": "string" }
          }
        },
        "kubernetesApiNoProxyHosts": {
          "type": "array",
          "items": { "type": "string" }
        },
        "kubernetesApiEgress": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cidr": { "type": "string" },
              "port": { "type": "integer" }
            },
            "required": ["cidr"]
          }
        },
        "enabledTools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disabledTools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "slackEtlEnabled": { "type": "boolean" },
        "slackSyncIntervalSeconds": { "type": "integer" },
        "slackSyncLookbackDays": { "type": "integer" },
        "slackSyncThreadLookbackDays": { "type": "integer" },
        "companyContextDocumentsIntervalSeconds": { "type": "integer" }
      }
    },
    "overlay": {
      "type": "object",
      "properties": {
        "mountPath": { "type": "string" },
        "systemPrompt": { "type": "string" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" },
            "sourcePath": { "type": "string" }
          }
        }
      }
    },
    "sandbox": {
      "type": "object",
      "properties": {
        "runtimeClassName": { "type": "string" },
        "reposPath": { "type": "string" },
        "resources": { "type": "object" }
      }
    },
    "repoCache": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "hostPath": { "type": "string" },
        "repositories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "syncIntervalSeconds": { "type": "integer" },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "githubToken": {
          "type": "object",
          "properties": {
            "existingSecretName": { "type": "string" },
            "secretKey": { "type": "string" },
            "token": { "type": "string" }
          }
        },
        "egressPorts": {
          "type": "array",
          "items": { "type": "integer" }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "resources": { "type": "object" }
      }
    },
    "agentSandbox": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "namespace": {
          "type": "object",
          "properties": {
            "create": { "type": "boolean" },
            "name": { "type": "string" }
          }
        },
        "image": {
          "type": "object",
          "properties": {
            "repository": { "type": "string" },
            "tag": { "type": "string" },
            "pullPolicy": { "type": "string" }
          }
        },
        "controller": {
          "type": "object",
          "properties": {
            "extensions": { "type": "boolean" }
          }
        }
      }
    },
    "slackbot": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "socketMode": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "postgres": {
      "type": "object",
      "properties": {
        "persistence": {
          "type": "object",
          "properties": {
            "subPath": { "type": "string" }
          }
        }
      }
    },
    "runnerAccess": {
      "type": "object",
      "properties": {
        "allowedCidrs": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "ingress": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "host": { "type": "string" },
        "tls": { "type": "array" },
        "slackbot": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string" },
            "annotations": { "type": "object" },
            "host": { "type": "string" },
            "tls": { "type": "array" }
          }
        },
        "api": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "className": { "type": "string" },
            "annotations": { "type": "object" },
            "host": { "type": "string" },
            "tls": { "type": "array" }
          }
        }
      }
    },
    "networkPolicy": {
      "type": "object",
      "properties": {
        "enabled": { "type": "boolean" },
        "ingressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "apiIngressSourceNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ingressControllerNamespaces": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
